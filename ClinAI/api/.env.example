# Copy this file to ClinAI/api/.env and fill in your values

# Required — LLM + transcription
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_api_key_here

# MCP server path (Windows example)
SERVER_SCRIPT_PATH=C:\Users\manoj\OneDrive\Desktop\clinai-agent\ClinAI_server\main.py

# MongoDB Atlas (optional — skip if using SQLite + Chroma instead)
# ATLAS_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB_NAME=clinical_data
# MONGODB_COLLECTION=patient_records

# Chroma vector store (local, no account needed)
CHROMA_PERSIST_DIR=./chroma_data
